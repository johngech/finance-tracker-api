# ==========================================
# FinanceTracker Environment Variables
# ==========================================
# Copy this file to .env and fill in values
# NEVER commit .env to version control
#
# Load with: set -a && source .env && set +a

# ---- Dev (optional overrides) ----
SPRING_PROFILES_ACTIVE=dev
# DB_URL=jdbc:postgresql://localhost:5432/financetracker_dev
# DB_USERNAME=postgres
# DB_PASSWORD=changeme
# JWT_SECRET=your-dev-jwt-secret
# CORS_ORIGIN=http://localhost:3000

# ---- Stag (required) ----
# SPRING_PROFILES_ACTIVE=stag
# DB_URL=jdbc:postgresql://stag-host:5432/financetracker
# DB_USERNAME=stag_user
# DB_PASSWORD=stag_secure_password
# JWT_SECRET=stag_jwt_secret_at_least_32_chars
# CORS_ORIGIN=https://stag.yourdomain.com

# ---- Prod (required) ----
# SPRING_PROFILES_ACTIVE=prod
# DB_URL=jdbc:postgresql://prod-host:5432/financetracker
# DB_USERNAME=prod_user
# DB_PASSWORD=prod_secure_password
# JWT_SECRET=prod_jwt_secret_at_least_32_chars
# CORS_ORIGIN=https://yourdomain.com
